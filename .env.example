# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# ВАЖНО: именно SUPABASE_SERVICE_KEY (не SUPABASE_SERVICE_ROLE_KEY!)
SUPABASE_SERVICE_KEY=eyJ...

# ── AI-провайдер (GigaChat от Сбера) ─────────────────────────────────────────
# Получить: https://developers.sber.ru/portal/products/gigachat
AI_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AI_CLIENT_SECRET=ваш_секрет
AI_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
AI_CHAT_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions
AI_SCOPE=GIGACHAT_API_PERS

# ── SaluteSpeech (распознавание речи от Сбера) ───────────────────────────────
# Получить: https://developers.sber.ru/portal/products/smartspeech
# Вариант 1: статический токен (проще, действует 30 мин - нужно обновлять)
SPEECH_TOKEN=ваш_salutespeech_токен
# Вариант 2: OAuth (рекомендуется для продакшена)
# SPEECH_CLIENT_ID=...
# SPEECH_CLIENT_SECRET=...
SPEECH_URL=https://smartspeech.sber.ru/rest/v1/speech:recognize

# ── UnitPay (приём платежей) ──────────────────────────────────────────────────
# Получить: https://unitpay.money/
UNITPAY_PROJECT_ID=ваш_project_id
UNITPAY_PUBLIC_KEY=ваш_public_key
UNITPAY_SECRET_KEY=ваш_secret_key

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Создать бота: @BotFather в Telegram → /newbot
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_USERNAME=ResumeVoiceBot

# ── Сайт ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://resumevoice.ru

# ── SEO верификация ───────────────────────────────────────────────────────────
# Яндекс.Вебмастер → Добавить сайт → HTML-тег → скопировать content
NEXT_PUBLIC_YANDEX_VERIFICATION=ваш_код_яндекс
# Google Search Console → Добавить ресурс → HTML-тег → скопировать content
NEXT_PUBLIC_GOOGLE_VERIFICATION=ваш_код_google

# ── Защита служебных роутов ───────────────────────────────────────────────────
# Любая случайная строка для /api/telegram/setup?secret=...
SETUP_SECRET=смените_на_случайную_строку

# ── Администратор ─────────────────────────────────────────────────────────────
# Логин администратора
ADMIN_LOGIN=admin

# SHA-256 хеш пароля (НЕ сам пароль!)
# Как получить хеш:
#   node -e "const c=require('crypto');console.log(c.createHash('sha256').update('ВАШ_ПАРОЛЬ').digest('hex'))"
# Пример ниже — хеш строки "changeme" — ОБЯЗАТЕЛЬНО замените!
ADMIN_PASSWORD_HASH=ВСТАВЬТЕ_SHA256_ХЕШ_ВАШЕГО_ПАРОЛЯ
